      "link": null,
      "locked": false,
      "text": "He practiced too anxiously, and as a result,\nhe caught fire and entered a demon.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "JiQsy6a9t4eWMkmjz4Ucm",
      "originalText": "He practiced too anxiously, and as a result, he caught fire and entered a demon.",
      "autoResize": true,
